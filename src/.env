# ============================================
# 多模态RAG系统配置文件
# ============================================

# --------------------------------------------
# 基础路径配置 (相对路径，相对于项目根目录)
# --------------------------------------------
# 项目根目录 (使用 . 表示当前目录)
BASE_DIR=.

# PDF文件路径 (相对于RESOURCE_DIR)
PDF_NAME=5566778899.pdf

# --------------------------------------------
# API密钥配置
# --------------------------------------------
# 阿里云DashScope API Key
DASHSCOPE_API_KEY=sk-1968b4bc6473413fab4baf3d9470cb99

# --------------------------------------------
# 外部工具路径配置 (相对路径)
# --------------------------------------------
# Poppler工具路径 (用于PDF处理) - 使用绝对路径
POPPLER_PATH=D:\Multimodal_RAG\tools\Release-24.08.0-0\poppler-24.08.0\Library\bin

# Tesseract OCR路径 (用于图片文字识别) - 使用绝对路径
TESSERACT_PATH=D:\Multimodal_RAG\tools\Tesseract-OCR\tesseract-ocr-w64-setup-5.5.0.20241111

# --------------------------------------------
# 模型配置
# --------------------------------------------
# 使用的LLM模型名称
LLM_MODEL=qwen-max

# 使用的多模态模型名称
VL_MODEL=qwen-vl-max

# 使用的嵌入模型名称
EMBEDDING_MODEL=text-embedding-v1

# 使用的多模态嵌入模型名称
MULTIMODAL_EMBEDDING_MODEL=multimodal-embedding-v1

# --------------------------------------------
# HuggingFace配置
# --------------------------------------------
# HuggingFace镜像地址 (国内用户建议使用)
HF_ENDPOINT=https://hf-mirror.com

# 是否离线模式
# HF_HUB_OFFLINE=0
